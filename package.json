{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "clockify",
  "title": "Clockify",
  "description": "Hours report with daily summary and balance from Clockify",
  "icon": "extension-icon.png",
  "author": "lars",
  "license": "MIT",
  "commands": [
    {
      "name": "report",
      "title": "Report",
      "description": "Hours report with daily summary and balance",
      "mode": "view"
    },
    {
      "name": "add-days-off",
      "title": "Add Days Off",
      "description": "Add days off to the counter",
      "mode": "no-view",
      "arguments": [
        {
          "name": "amount",
          "placeholder": "Days",
          "type": "text",
          "required": false
        }
      ]
    },
    {
      "name": "remove-days-off",
      "title": "Remove Days Off",
      "description": "Remove days off from the counter",
      "mode": "no-view",
      "arguments": [
        {
          "name": "amount",
          "placeholder": "Days",
          "type": "text",
          "required": false
        }
      ]
    },
    {
      "name": "reset-days-off",
      "title": "Reset Days Off",
      "description": "Reset days off counter to zero",
      "mode": "no-view"
    }
  ],
  "preferences": [
    {
      "name": "apiKey",
      "title": "Clockify API Key",
      "description": "Your Clockify API key",
      "type": "password",
      "required": true
    },
    {
      "name": "hoursPerDay",
      "title": "Hours per Day",
      "description": "Expected working hours per day",
      "type": "textfield",
      "default": "8",
      "required": false
    },
    {
      "name": "federalState",
      "title": "Bundesland",
      "description": "Bundesland für Feiertagsberechnung",
      "type": "dropdown",
      "required": false,
      "data": [
        { "title": "Keine Feiertage", "value": "" },
        { "title": "Baden-Württemberg", "value": "BW" },
        { "title": "Bayern", "value": "BY" },
        { "title": "Berlin", "value": "BE" },
        { "title": "Brandenburg", "value": "BB" },
        { "title": "Bremen", "value": "HB" },
        { "title": "Hamburg", "value": "HH" },
        { "title": "Hessen", "value": "HE" },
        { "title": "Mecklenburg-Vorpommern", "value": "MV" },
        { "title": "Niedersachsen", "value": "NI" },
        { "title": "Nordrhein-Westfalen", "value": "NW" },
        { "title": "Rheinland-Pfalz", "value": "RP" },
        { "title": "Saarland", "value": "SL" },
        { "title": "Sachsen", "value": "SN" },
        { "title": "Sachsen-Anhalt", "value": "ST" },
        { "title": "Schleswig-Holstein", "value": "SH" },
        { "title": "Thüringen", "value": "TH" }
      ]
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.100.0",
    "@raycast/utils": "^1.19.0"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^1.0.11",
    "@types/node": "~22.13.0",
    "@types/react": "^19.0.0",
    "eslint": "^8.57.1",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.0"
  },
  "scripts": {
    "dev": "ray develop",
    "build": "ray build -e dist",
    "lint": "ray lint",
    "fix-lint": "ray lint --fix",
    "test": "vitest run",
    "test:watch": "vitest"
  }
}
