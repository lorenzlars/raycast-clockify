{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "clockify",
  "title": "Clockify",
  "description": "Hours report with daily summary and balance from Clockify",
  "icon": "extension-icon.png",
  "author": "lars",
  "license": "MIT",
  "commands": [
    {
      "name": "report",
      "title": "Report",
      "description": "Hours report with daily summary and balance",
      "mode": "view"
    }
  ],
  "preferences": [
    {
      "name": "apiKey",
      "title": "Clockify API Key",
      "description": "Your Clockify API key",
      "type": "password",
      "required": true
    },
    {
      "name": "hoursPerDay",
      "title": "Hours per Day",
      "description": "Expected working hours per day",
      "type": "textfield",
      "default": "8",
      "required": false
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.100.0",
    "@raycast/utils": "^1.19.0"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^1.0.11",
    "@types/node": "~22.13.0",
    "@types/react": "^19.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0"
  },
  "scripts": {
    "dev": "ray develop",
    "build": "ray build -e dist",
    "lint": "ray lint"
  }
}